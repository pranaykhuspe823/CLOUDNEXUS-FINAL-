# CloudNexus Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── AWS (optional — can also connect via the UI) ────────────────────────────
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_REGION=us-east-1
# AWS_SESSION_TOKEN=                    # Only needed for temporary credentials

# ── GCP (optional — can also connect via the UI) ────────────────────────────
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT_ID=my-gcp-project

# ── Azure (optional — can also connect via the UI) ──────────────────────────
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Logging ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
